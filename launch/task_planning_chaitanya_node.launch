<launch>
	<arg name="namespace" default="sim" />
	<group ns="$(arg namespace)">	

		<node name="gp4_lego_integrate_task_planning_chaitanya" pkg="aidf" type="gp4_lego_integrate_task_planning_chaitanya" output="screen" required="true">
			<param name="config_fname" value="$(find aidf)/config/lego_tasks/user_config_chaitanya.json" />
			<param name="root_pwd" value="$(find aidf)/" />
			<param if="$(eval namespace == 'yk_creator')" name="x_home" value="0.3" />
            <param if="$(eval namespace == 'yk_creator')" name="y_home" value="0.1" />
            <param if="$(eval namespace == 'yk_builder')" name="x_home" value="0.3" />
            <param if="$(eval namespace == 'yk_builder')" name="y_home" value="0.1" />
            <param if="$(eval namespace == 'yk_architect')" name="x_home" value="0.3" />
            <param if="$(eval namespace == 'yk_architect')" name="y_home" value="0" />
            <param if="$(eval namespace == 'yk_destroyer')" name="x_home" value="0" />
            <param if="$(eval namespace == 'yk_destroyer')" name="y_home" value="0.3" />
		</node>

	</group>
</launch>
